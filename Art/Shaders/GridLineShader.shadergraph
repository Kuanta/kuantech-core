            "m_Id": "b7d2c7bcfe83413db2f7a5693545cea9"
        },
        {
            "m_Id": "34106e531ed4476bb307640e6af3c97c"
        },
        {
            "m_Id": "a6f2e1a42b10471688066c88ac3bf813"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "GridPattern",
    "m_FunctionSource": "d962ea27e24f551489d715afac4599d8",
    "m_FunctionBody": "float CheckeredPattern(float3 objectPos, float tileSize)\r\n{\r\n    int x = (int)(objectPos.x / tileSize);\r\n    int z = (int)(objectPos.z / tileSize);\r\n    \r\n    return (x + z) % 2 == 0 ? 1.0 : 0.0;\r\n}"
}

